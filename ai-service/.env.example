# Image Server Provider
# - mock: return fake image URLs for local development and CI
# - huggingface: generate real images using Hugging Face Diffusers
IMAGE_SERVER_PROVIDER=mock

# This is used to build the image_url returned by /generate.
# Local example:
IMAGE_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8001

# EC2 example:
# IMAGE_SERVER_PUBLIC_BASE_URL=http://ec2-your-public-dns.compute-1.amazonaws.com:8001


# Directory where generated PNG files are saved.
IMAGE_OUTPUT_DIR=generated

# Huggingface
# Used only when IMAGE_SERVER_PROVIDER=huggingface.
# Tiny local test model:
HF_MODEL_ID=hf-internal-testing/tiny-stable-diffusion-pipe

# EC2 GPU model example:
# HF_MODEL_ID=stabilityai/sdxl-turbo

# Optional.
# Useful for private/gated models or better Hugging Face Hub rate limits.
# This 
# Do not commit a real token.
HF_TOKEN=